class Solution {
    public int maxDepth(Node root) {
        if(root == null){
            return 0;
        }

        Deque<Node> que = new LinkedList<Node>();

        que.offer(root);
        int depth = 0;
        while(!que.isEmpty()){
            int levelSize = que.size();
            for(int i = 0; i < levelSize; i++){
                Node node = que.poll();

                for(Node child : node.children){
                    que.offer(child);
                }
            }
            depth++;
        }
        return depth;

    }
}
